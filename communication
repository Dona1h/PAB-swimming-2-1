        <label className="label">잔류염소 (ppm)</label>
        <input className="input" type="number" step="0.1" placeholder="예: 0.8" value={data.chlorine} onChange={e=>set('chlorine',e.target.value)}/>
      </div>
      <div className="form-group">
        <label className="label">기계 상태</label>
        <select className="input" value={data.machineStatus} onChange={e=>set('machineStatus',e.target.value)}>
          <option>정상</option><option>점검필요</option><option>고장</option>
        </select>
      </div>
      <div className="form-group">
        <label className="label">수리/점검 현황</label>
        <textarea className="input" placeholder="없으면 '없음'" value={data.repairNote} onChange={e=>set('repairNote',e.target.value)}/>
      </div>
      <div className="form-group">
        <label className="label">긴급도</label>
        <div className="urgency-select">
          {[['green','🟢 일반'],['yellow','🟡 주의'],['red','🔴 긴급']].map(([k,l])=>
            <div key={k} className={`urgency-opt ${data.urgency===k?'selected':''}`}
              style={{color:k==='green'?'var(--green)':k==='yellow'?'var(--amber)':'var(--red)',
                borderColor:data.urgency===k?(k==='green'?'var(--green)':k==='yellow'?'var(--amber)':'var(--red)'):'var(--border)'}}
