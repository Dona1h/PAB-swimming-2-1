// LEAD DASHBOARD
// ═══════════════════════════════════════════════════
function LeadDashboard({reports, announcements, onAnnounce}){
  const [tab, setTab] = useState('today');
  const [selectedReport, setSelectedReport] = useState(null);
  const [annoText, setAnnoText] = useState('');
  const [annoDept, setAnnoDept] = useState('전체');
  const today = DB.today();
  const todayReports = reports.filter(r=>r.date===today);

  const reporterIds = ['machine','clean','swim_am','swim_pm','swim_kids','mgr_chief'];
  const reportStatus = reporterIds.map(id=>{
    const staff = STAFF.find(s=>s.id===id);
    const report = todayReports.find(r=>r.userId===id);
    return {staff, report, deadline: REPORT_DEADLINES[id]};
  });
  const doneCount = reportStatus.filter(r=>r.report).length;
  const urgentCount = todayReports.filter(r=>r.data.urgency==='red').length;

  // Weekly sales
  const weekReports = reports.filter(r=>{
    const d=new Date(r.date),now=new Date(),mon=new Date(now);
    mon.setDate(now.getDate()-now.getDay()+1);mon.setHours(0,0,0,0);
    return d>=mon && r.data.formType==='manager';
  });
  const weeklySales = weekReports.reduce((s,r)=>s+(Number(r.data.sales)||0),0);

  return (
    <div className="content fade-in">
      <div className="tab-bar">
        <button className={`tab-btn ${tab==='today'?'active':''}`} onClick={()=>setTab('today')}>📊 현황</button>
        <button className={`tab-btn ${tab==='reports'?'active':''}`} onClick={()=>setTab('reports')}>📋 보고</button>
        <button className={`tab-btn ${tab==='weekly'?'active':''}`} onClick={()=>setTab('weekly')}>📈 주간</button>
        <button className={`tab-btn ${tab==='announce'?'active':''}`} onClick={()=>setTab('announce')}>📢 공지</button>
      </div>

      {tab==='today' && <>
        <div className="stat-grid">
          <div className="stat-card" style={{background:'#EFF6FF'}}>
            <div className="value" style={{color:'var(--sky)'}}>{doneCount}/{reporterIds.length}</div>
            <div className="label">보고 완료</div>
            <div className="progress-bar"><div className="progress-fill" style={{width:`${doneCount/reporterIds.length*100}%`,background:'var(--sky)'}}/></div>
          </div>
          <div className="stat-card" style={{background:urgentCount>0?'#FEF2F2':'#F0FDF4'}}>
            <div className="value" style={{color:urgentCount>0?'var(--red)':'var(--green)'}}>{urgentCount}</div>
            <div className="label">긴급사항</div>
          </div>
          <div className="stat-card" style={{background:'#FFF7ED'}}>
            <div className="value" style={{color:'var(--amber)',fontSize:18}}>{weeklySales?weeklySales.toLocaleString()+'원':'-'}</div>
            <div className="label">주간 매출</div>
          </div>
          <div className="stat-card" style={{background:'#F5F3FF'}}>
            <div className="value" style={{color:'var(--purple)'}}>{todayReports.length}</div>
            <div className="label">오늘 총 보고</div>
          </div>
        </div>

        <h3 style={{fontSize:14,fontWeight:700,margin:'16px 0 8px'}}>보고 현황</h3>
        {reportStatus.map(({staff,report,deadline},i)=>(
          <div key={i} className="report-item card" style={{padding:10,cursor:report?'pointer':'default'}}
            onClick={()=>report&&setSelectedReport(report)}>
            <div className="dot" style={{background:report?'var(--green)':'#cbd5e1'}}/>
            <div style={{flex:1}}>
              <div style={{fontSize:13,fontWeight:600}}>{staff.name}</div>
              <div style={{fontSize:11,color:'var(--text2)'}}>{staff.dept} · 마감 {deadline}</div>
            </div>
            <span className="badge" style={{background:report?'#D1FAE5':'#F1F5F9',color:report?'var(--green)':'#94a3b8',fontSize:11}}>
              {report?`${report.time} 완료`:'대기'}
            </span>
          </div>
        ))}

        {selectedReport && (
          <div className="modal-overlay" onClick={()=>setSelectedReport(null)}>
            <div className="modal" onClick={e=>e.stopPropagation()}>
              <div style={{display:'flex',justifyContent:'space-between',alignItems:'center',marginBottom:16}}>
                <h3 style={{fontSize:16,fontWeight:700}}>📋 보고 상세</h3>
                <button onClick={()=>setSelectedReport(null)} style={{border:'none',background:'none',fontSize:20,cursor:'pointer'}}>✕</button>
              </div>
              <div style={{marginBottom:8}}>
                <span className="badge" style={{background:DEPT_COLORS[STAFF.find(s=>s.id===selectedReport.userId)?.dept]+'20',
                  color:DEPT_COLORS[STAFF.find(s=>s.id===selectedReport.userId)?.dept]}}>
                  {STAFF.find(s=>s.id===selectedReport.userId)?.dept}
                </span>
                <span style={{fontSize:13,fontWeight:600,marginLeft:8}}>{STAFF.find(s=>s.id===selectedReport.userId)?.name}</span>
              </div>
              <p style={{fontSize:12,color:'var(--text2)',marginBottom:16}}>{selectedReport.date} {selectedReport.time}</p>
              {Object.entries(selectedReport.data).filter(([k])=>!['formType','urgency'].includes(k)).map(([k,v])=>
                v ? <div key={k} style={{padding:'8px 0',borderBottom:'1px solid var(--border)'}}>
                  <div style={{fontSize:11,color:'var(--text2)',marginBottom:2}}>{k}</div>
                  <div style={{fontSize:14}}>{v}</div>
                </div> : null
              )}
              <div style={{padding:'8px 0'}}>
                <div style={{fontSize:11,color:'var(--text2)',marginBottom:2}}>긴급도</div>
                <div style={{fontSize:14}}>{selectedReport.data.urgency==='green'?'🟢 일반':selectedReport.data.urgency==='yellow'?'🟡 주의':'🔴 긴급'}</div>
              </div>
            </div>
          </div>
        )}
      </>}

      {tab==='reports' && <>
        <h3 style={{fontSize:14,fontWeight:700,marginBottom:12}}>전체 보고 내역</h3>
        {reports.slice(-30).reverse().map((r,i)=>{
          const staff = STAFF.find(s=>s.id===r.userId);
          return (
            <div key={i} className="card" style={{padding:10,cursor:'pointer'}} onClick={()=>setSelectedReport(r)}>
              <div style={{display:'flex',alignItems:'center',gap:8}}>
                <span className="badge" style={{background:(DEPT_COLORS[staff?.dept]||'#666')+'20',color:DEPT_COLORS[staff?.dept]||'#666',fontSize:10}}>
                  {staff?.dept}
                </span>
                <span style={{fontSize:13,fontWeight:600,flex:1}}>{staff?.name}</span>
                <span style={{fontSize:11,color:'var(--text2)'}}>{r.date} {r.time}</span>
              </div>
            </div>
          );
        })}
      </>}

      {tab==='weekly' && <WeeklyReport reports={reports}/>}

      {tab==='announce' && <>
        <div className="card" style={{padding:16}}>
          <div className="form-group">
            <label className="label">수신 부서</label>
            <select className="input" value={annoDept} onChange={e=>setAnnoDept(e.target.value)}>
              <option>전체</option><option>수영팀</option><option>매니저팀</option><option>미화팀</option><option>기계팀</option>
            </select>
          </div>
          <div className="form-group">
            <label className="label">공지 내용</label>
            <textarea className="input" value={annoText} onChange={e=>setAnnoText(e.target.value)} placeholder="공지 내용을 입력하세요"/>
          </div>
          <button className="btn btn-primary btn-block" disabled={!annoText.trim()}
            onClick={()=>{onAnnounce({dept:annoDept,text:annoText,date:DB.today(),time:DB.now()});setAnnoText('')}}>
            📢 공지 발송
          </button>
        </div>
        <h3 style={{fontSize:14,fontWeight:700,margin:'16px 0 8px'}}>발송된 공지</h3>
        {announcements.slice().reverse().map((a,i)=>(
          <div key={i} className="card" style={{padding:12}}>
            <div style={{display:'flex',justifyContent:'space-between',marginBottom:4}}>
              <span className="badge" style={{background:'#EFF6FF',color:'var(--sky)'}}>{a.dept}</span>
              <span style={{fontSize:11,color:'var(--text2)'}}>{a.date} {a.time}</span>
            </div>
            <p style={{fontSize:13,marginTop:6}}>{a.text}</p>
          </div>
        ))}
      </>}
    </div>
  );
}

