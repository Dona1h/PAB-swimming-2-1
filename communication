// SETTINGS SCREEN
// ═══════════════════════════════════════════════════
function SettingsScreen({user, onLogout, reports, announcements}){
  const [showConfirm, setShowConfirm] = useState(false);

  const exportData = () => {
    const data = {reports, announcements, exported: new Date().toISOString()};
    const blob = new Blob([JSON.stringify(data,null,2)],{type:'application/json'});
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a'); a.href=url; a.download=`PAB_백업_${DB.today()}.json`; a.click();
    URL.revokeObjectURL(url);
  };

  const importData = () => {
    const input = document.createElement('input'); input.type='file'; input.accept='.json';
    input.onchange = e => {
      const file = e.target.files[0]; if(!file) return;
      const reader = new FileReader();
      reader.onload = ev => {
        try {
          const data = JSON.parse(ev.target.result);
          if(data.reports) DB.set('reports', data.reports);
          if(data.announcements) DB.set('announcements', data.announcements);
          window.location.reload();
        } catch{ alert('잘못된 파일입니다.'); }
      };
      reader.readAsText(file);
    };
    input.click();
  };

  return (
    <div className="content fade-in">
      <div className="card" style={{padding:16}}>
        <div style={{display:'flex',alignItems:'center',gap:12,marginBottom:12}}>
          <div style={{width:44,height:44,borderRadius:22,background:'var(--sky)',color:'#fff',display:'flex',alignItems:'center',justifyContent:'center',fontSize:18,fontWeight:700}}>
            {user.name[0]}
          </div>
          <div>
            <div style={{fontWeight:700}}>{user.name}</div>
            <div style={{fontSize:12,color:'var(--text2)'}}>{user.dept} · {user.role==='lead'?'운영팀장':user.role==='exec'?'운영진':'담당자'}</div>
          </div>
        </div>
      </div>

      <h3 style={{fontSize:14,fontWeight:700,margin:'16px 0 8px'}}>데이터 관리</h3>
      <div className="card" style={{padding:0}}>
        <button style={{width:'100%',padding:14,border:'none',background:'none',fontSize:14,textAlign:'left',borderBottom:'1px solid var(--border)',cursor:'pointer'}}
          onClick={exportData}>📤 데이터 백업 (JSON 다운로드)</button>
        <button style={{width:'100%',padding:14,border:'none',background:'none',fontSize:14,textAlign:'left',borderBottom:'1px solid var(--border)',cursor:'pointer'}}
          onClick={importData}>📥 데이터 복원 (JSON 업로드)</button>
        <button style={{width:'100%',padding:14,border:'none',background:'none',fontSize:14,textAlign:'left',color:'var(--text2)',cursor:'pointer'}}
          onClick={()=>{}}>📊 보고 {reports.length}건 · 공지 {announcements.length}건</button>
      </div>

      <div style={{marginTop:24}}>
        <button className="btn btn-outline btn-block" onClick={onLogout}>로그아웃</button>
      </div>

      <p style={{textAlign:'center',fontSize:11,color:'#bbb',marginTop:24}}>PAB 커뮤니케이션 v1.0</p>
    </div>
  );
}

// ═══════════════════════════════════════════════════
// MAIN APP
// ═══════════════════════════════════════════════════
function App(){
  const [userId, setUserId] = useState(()=>DB.get('currentUser'));
  const [reports, setReports] = useState(()=>DB.get('reports',[]));
  const [announcements, setAnnouncements] = useState(()=>DB.get('announcements',[]));
  const [activeTab, setActiveTab] = useState('home');
  const [toast, setToast] = useState(null);

  const user = STAFF.find(s=>s.id===userId);

  useEffect(()=>{DB.set('reports',reports)},[reports]);
  useEffect(()=>{DB.set('announcements',announcements)},[announcements]);

  const login = (id) => { DB.set('currentUser',id); setUserId(id); setActiveTab('home'); };
  const logout = () => { DB.set('currentUser',null); setUserId(null); };

  const submitReport = (data) => {
    const report = {userId, date:DB.today(), time:DB.now(), data};
    setReports(prev=>[...prev, report]);
    setToast({msg:'✅ 보고가 제출되었습니다!', type:'success'});
  };

  const addAnnouncement = (anno) => {
    setAnnouncements(prev=>[...prev, anno]);
    setToast({msg:'📢 공지가 발송되었습니다', type:'info'});
  };

  if(!userId) return <LoginScreen onLogin={login}/>;
  if(!user) { logout(); return null; }

  const todayUrgent = reports.filter(r=>r.date===DB.today()&&r.data.urgency==='red').length;
  const todayAnnounce = announcements.filter(a=>a.date===DB.today()).length;

  // Staff view
  const navItems = user.role==='staff' ? [
    {id:'home',icon:'📝',label:'보고'},
    {id:'notice',icon:'📢',label:'공지'},
    {id:'settings',icon:'⚙️',label:'설정'},
  ] : user.role==='lead' ? [
    {id:'home',icon:'📊',label:'대시보드'},
    {id:'notice',icon:'📢',label:'공지'},
    {id:'settings',icon:'⚙️',label:'설정'},
  ] : [
    {id:'home',icon:'📈',label:'현황'},
    {id:'notice',icon:'📢',label:'공지'},
    {id:'settings',icon:'⚙️',label:'설정'},
  ];

  return (
    <div className="app">
      {toast && <Toast msg={toast.msg} type={toast.type} onClose={()=>setToast(null)}/>}

      <div className="header">
        <div className="header-inner">
          <h1>🏊 PAB 커뮤니케이션</h1>
          <div style={{display:'flex',alignItems:'center',gap:8}}>
            {todayUrgent>0 && <span className="badge" style={{background:'#FEE2E2',color:'var(--red)'}}>🚨 {todayUrgent}</span>}
            <span style={{fontSize:12,color:'var(--text2)'}}>{user.name}</span>
          </div>
        </div>
        <div style={{fontSize:12,color:'var(--text2)',paddingBottom:8}}>{DB.todayLabel()}</div>
      </div>

      {activeTab==='home' && user.role==='staff' && <StaffScreen user={user} reports={reports} onSubmit={submitReport}/>}
      {activeTab==='home' && user.role==='lead' && <LeadDashboard reports={reports} announcements={announcements} onAnnounce={addAnnouncement}/>}
      {activeTab==='home' && user.role==='exec' && <ExecScreen reports={reports}/>}

      {activeTab==='notice' && (
        <div className="content fade-in">
          <h2 style={{fontSize:16,fontWeight:700,marginBottom:12}}>📢 공지사항</h2>
          {announcements.filter(a=>user.role!=='staff'||a.dept==='전체'||a.dept===user.dept).length===0 ? (
            <div className="empty-state"><div className="icon">📢</div><p>공지사항이 없습니다</p></div>
          ) : announcements.filter(a=>user.role!=='staff'||a.dept==='전체'||a.dept===user.dept).slice().reverse().map((a,i)=>(
            <div key={i} className="card" style={{padding:12}}>
              <div style={{display:'flex',justifyContent:'space-between',marginBottom:4}}>
                <span className="badge" style={{background:'#EFF6FF',color:'var(--sky)'}}>{a.dept}</span>
                <span style={{fontSize:11,color:'var(--text2)'}}>{a.date} {a.time}</span>
              </div>
              <p style={{fontSize:14,marginTop:8,lineHeight:1.5}}>{a.text}</p>
            </div>
          ))}
        </div>
      )}

      {activeTab==='settings' && <SettingsScreen user={user} onLogout={logout} reports={reports} announcements={announcements}/>}

      <div className="nav">
        {navItems.map(item=>(
          <button key={item.id} className={activeTab===item.id?'active':''} onClick={()=>setActiveTab(item.id)}>
            <span className="icon">{item.icon}</span>
            {item.label}
            {item.id==='notice' && todayAnnounce>0 && <span className="notif">{todayAnnounce}</span>}
          </button>
        ))}
      </div>
    </div>
  );
}

ReactDOM.createRoot(document.getElementById('root')).render(<App/>);
</script>
</body>
