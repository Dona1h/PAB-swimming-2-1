}

function HandoverForm({user, onSubmit}){
  const [data, setData] = useState({pending:'',caution:'',note:''});
  const set = (k,v) => setData(p=>({...p,[k]:v}));
  return (
    <div className="fade-in">
      <div className="form-group">
        <label className="label">미처리 건</label>
        <textarea className="input" placeholder="인수인계할 미처리 건" value={data.pending} onChange={e=>set('pending',e.target.value)}/>
      </div>
      <div className="form-group">
        <label className="label">주의사항</label>
        <textarea className="input" placeholder="주의해야 할 사항" value={data.caution} onChange={e=>set('caution',e.target.value)}/>
      </div>
      <div className="form-group">
        <label className="label">기타 전달사항</label>
        <textarea className="input" placeholder="추가 전달사항" value={data.note} onChange={e=>set('note',e.target.value)}/>
      </div>
      <button className="btn btn-primary btn-block" onClick={()=>onSubmit({...data,formType:'handover',urgency:'green'})}>인수인계 제출</button>
    </div>
  );
}

// ═══════════════════════════════════════════════════
// STAFF SCREEN
// ═══════════════════════════════════════════════════
function StaffScreen({user, reports, onSubmit}){
  const [tab, setTab] = useState('report');
  const todayReport = reports.find(r=>r.date===DB.today()&&r.userId===user.id);
  const myReports = reports.filter(r=>r.userId===user.id).slice(-20).reverse();

  const FormComponent = {swimming:SwimmingForm, manager:ManagerForm, cleaning:CleaningForm, machine:MachineForm, handover:HandoverForm}[user.formType];

  return (
    <div className="content fade-in">
      <div className="tab-bar">
        <button className={`tab-btn ${tab==='report'?'active':''}`} onClick={()=>setTab('report')}>
          {todayReport?'✅ 보고완료':'📝 보고하기'}
        </button>
        <button className={`tab-btn ${tab==='history'?'active':''}`} onClick={()=>setTab('history')}>📋 내 이력</button>
      </div>

      {tab==='report' && (
        todayReport ? (
          <div className="card" style={{textAlign:'center',padding:32}}>
            <div style={{fontSize:48,marginBottom:12}}>✅</div>
            <h3 style={{fontSize:16,fontWeight:700}}>오늘 보고 완료</h3>
            <p style={{color:'var(--text2)',fontSize:13,marginTop:8}}>제출 시간: {todayReport.time}</p>
            <p style={{color:'var(--text2)',fontSize:13}}>긴급도: {todayReport.data.urgency==='green'?'🟢 일반':todayReport.data.urgency==='yellow'?'🟡 주의':'🔴 긴급'}</p>
          </div>
        ) : FormComponent ? <FormComponent user={user} onSubmit={onSubmit}/> : null
      )}

      {tab==='history' && (
        myReports.length===0 ? (
          <div className="empty-state"><div className="icon">📋</div><p>보고 이력이 없습니다</p></div>
        ) : myReports.map((r,i)=>(
          <div key={i} className="card" style={{padding:12}}>
            <div style={{display:'flex',justifyContent:'space-between',alignItems:'center',marginBottom:6}}>
              <span style={{fontSize:13,fontWeight:700}}>{r.date}</span>
              <span className="badge" style={{background:r.data.urgency==='green'?'#D1FAE5':r.data.urgency==='yellow'?'#FEF3C7':'#FEE2E2',
                color:r.data.urgency==='green'?'var(--green)':r.data.urgency==='yellow'?'var(--amber)':'var(--red)'}}>
                {r.data.urgency==='green'?'일반':r.data.urgency==='yellow'?'주의':'긴급'}
              </span>
            </div>
            <p style={{fontSize:12,color:'var(--text2)'}}>제출: {r.time}</p>
          </div>
        ))
      )}
    </div>
  );
}

