// WEEKLY REPORT
// ═══════════════════════════════════════════════════
function WeeklyReport({reports}){
  const now = new Date();
  const mon = new Date(now); mon.setDate(now.getDate()-now.getDay()+1); mon.setHours(0,0,0,0);
  const weekReports = reports.filter(r=>new Date(r.date)>=mon);

  const days = ['월','화','수','목','금'];
  const depts = ['수영팀','매니저팀','미화팀','기계팀'];

  const salesData = weekReports.filter(r=>r.data.formType==='manager');
  const totalSales = salesData.reduce((s,r)=>s+(Number(r.data.sales)||0),0);
  const totalReg = salesData.reduce((s,r)=>s+(Number(r.data.newReg)||0),0);

  const urgents = weekReports.filter(r=>r.data.urgency==='red');

  return (
    <div className="fade-in">
      <div className="card" style={{padding:16}}>
        <h3 style={{fontSize:15,fontWeight:700,marginBottom:12}}>📈 이번 주 요약</h3>
        <div className="stat-grid">
          <div style={{padding:10,background:'#EFF6FF',borderRadius:8,textAlign:'center'}}>
            <div style={{fontSize:18,fontWeight:800,color:'var(--sky)'}}>{weekReports.length}</div>
            <div style={{fontSize:11,color:'var(--text2)'}}>총 보고</div>
          </div>
          <div style={{padding:10,background:'#FFF7ED',borderRadius:8,textAlign:'center'}}>
            <div style={{fontSize:14,fontWeight:800,color:'var(--amber)'}}>{totalSales?totalSales.toLocaleString()+'원':'-'}</div>
            <div style={{fontSize:11,color:'var(--text2)'}}>주간 매출</div>
          </div>
          <div style={{padding:10,background:'#F0FDF4',borderRadius:8,textAlign:'center'}}>
            <div style={{fontSize:18,fontWeight:800,color:'var(--green)'}}>{totalReg}</div>
            <div style={{fontSize:11,color:'var(--text2)'}}>신규 등록</div>
          </div>
          <div style={{padding:10,background:urgents.length>0?'#FEF2F2':'#F0FDF4',borderRadius:8,textAlign:'center'}}>
            <div style={{fontSize:18,fontWeight:800,color:urgents.length>0?'var(--red)':'var(--green)'}}>{urgents.length}</div>
            <div style={{fontSize:11,color:'var(--text2)'}}>긴급사항</div>
          </div>
        </div>
      </div>

      <div className="card" style={{padding:16,overflowX:'auto'}}>
        <h3 style={{fontSize:14,fontWeight:700,marginBottom:10}}>요일별 보고 현황</h3>
        <table style={{width:'100%',fontSize:12,borderCollapse:'collapse'}}>
          <thead>
            <tr style={{borderBottom:'2px solid var(--border)'}}>
              <th style={{padding:6,textAlign:'left'}}>부서</th>
              {days.map(d=><th key={d} style={{padding:6,textAlign:'center'}}>{d}</th>)}
            </tr>
          </thead>
          <tbody>
            {depts.map(dept=>(
              <tr key={dept} style={{borderBottom:'1px solid var(--border)'}}>
                <td style={{padding:6,fontWeight:600,color:DEPT_COLORS[dept]}}>{dept}</td>
                {[0,1,2,3,4].map(di=>{
                  const day = new Date(mon); day.setDate(mon.getDate()+di);
                  const ds = day.toISOString().slice(0,10);
                  const has = weekReports.some(r=>r.date===ds&&STAFF.find(s=>s.id===r.userId)?.dept===dept);
                  return <td key={di} style={{padding:6,textAlign:'center'}}>{has?'🟢':'⚪'}</td>;
                })}
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      {urgents.length>0 && (
        <div className="card" style={{padding:16,borderColor:'var(--red)'}}>
          <h3 style={{fontSize:14,fontWeight:700,color:'var(--red)',marginBottom:8}}>🚨 긴급사항 ({urgents.length}건)</h3>
          {urgents.map((r,i)=>(
            <div key={i} style={{padding:8,background:'#FEF2F2',borderRadius:8,marginBottom:6,fontSize:13}}>
              <strong>{STAFF.find(s=>s.id===r.userId)?.name}</strong> ({r.date}): {r.data.note||r.data.damage||r.data.repairNote||'-'}
            </div>
          ))}
        </div>
      )}
    </div>
  );
}

